{
    "name": "payplug/payplug-prestashop",
    "require": {
        "giggsey/libphonenumber-for-php": "^8.12",
        "payplug/payplug-php": "3.3.1"
    },
    "require-dev": {
        "phpunit/phpunit": "5.*",
        "ccinn/composer-husky-plugin": "^0.1.0",
        "ccinn/husky-php": "^0.1.0",
        "friendsofphp/php-cs-fixer": "^2.16"
    },
    "archive": {
        "exclude": [
            "!vendor/*",
            ".*",
            "tests",
            "view/css/less",
            "controllers/tools",
            "views/templates/front/tools",
            "test.php",
            "*.zip",
            "composer.*"
        ]
    },
    "autoload": {
        "psr-4": {
            "PayPlug\\": "./",
            "libphonenumberlight\\": "vendor/giggsey/libphonenumberlight"
        }
    },
    "config": {
        "prepend-autoloader": false
    },
    "scripts": {
        "post-install-cmd": [
            "./composer.sh"
        ],
        "post-update-cmd": [
            "./composer.sh"
        ],
        "install-dev": [
            "./composer_dev.sh"
        ]
    }
}
