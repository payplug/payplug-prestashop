{
    "name": "cyril/payplug",
    "require": {
        "giggsey/libphonenumber-for-php": "^8.12",
        "payplug/payplug-php": "3.*"
    },
    "require-dev": {
        "phpunit/phpunit": "9.*"
    },
    "autoload": {
        "psr-4": {
            "PayPlug\\": "./",
            "libphonenumberlight\\": "vendor/giggsey/libphonenumberlight"
        }
    },
    "config": {
        "prepend-autoloader": false
    },
    "scripts": {
        "post-install-cmd": [
            "./composer.sh"
        ],
        "post-update-cmd": [
            "./composer.sh"
        ]
    }
}
